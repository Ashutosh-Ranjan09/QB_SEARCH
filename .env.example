# =============================================================
# QuadBase — Root Environment Variables
# Copy this file to .env and fill in your real secrets.
# This file is read by docker-compose from the root directory.
# =============================================================

# ---- PostgreSQL (Neon or self-hosted) ----
PG_CONNECTION_STRING=postgresql://user:password@host/dbname?sslmode=require

# ---- JWT / Admin auth (must match JWT_SECRET in frontend) ----
ADMIN_SECRET=change_me_strong_secret
JWT_SECRET=change_me_strong_secret

# ---- Frontend public API URL ----
# This is baked into the Next.js build. Change the hostname
# if you are deploying behind a reverse proxy / domain.
NEXT_PUBLIC_API_URL=http://localhost:3001
